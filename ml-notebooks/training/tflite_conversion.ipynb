    "import tensorflow as tf\n",
    "model = tf.keras.models.load_model(\"D:\\\\SavedModels\\\\ResnetLatest.h5\")\n",
    "converter = tf.lite.TFLiteConverter.from_keras_model(model)\n",
    "tflite_model = converter.convert()\n",
    "open(\"D:\\\\SavedModels\\\\ResnetLatest.tflite\", \"wb\").write(tflite_model)"
   ]
